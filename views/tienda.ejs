<%- include('includes/head.ejs') %>
<%- include('includes/nav.ejs') %>

<section id="tienda" class="bg-white/10 backdrop-blur-md rounded-3xl p-12 mb-20 shadow-2xl">
  <h2 class="text-4xl font-bold text-center mb-12 bg-gradient-to-r from-emerald-400 to-teal-500 bg-clip-text text-transparent">
    🛒 Tiendita
  </h2>
  <p class="text-center text-lg mb-8 opacity-90">¡Las mejores cosas que verás jamás! IVA 16% MXN</p>

  <div class="grid md:grid-cols-3 gap-8 mb-12">
    <% for (let producto of productos) { %>
      <div class="bg-gradient-to-b from-gray-800 to-gray-900 p-8 rounded-2xl hover:scale-105 transition-all duration-300 border border-gray-700">
        <h3 class="text-2xl font-bold mb-2"><%= producto.nombre %></h3>
        <p class="text-green-400 text-xl mb-4 font-bold">$<%= producto.precio %> MXN</p>
        <p class="text-sm opacity-80 mb-4"><%= producto.descripcion %></p>
        <p class="text-sm opacity-80 mb-4">Máx: <%= producto.max %> unidades</p>
      </div>
    <% } %>
  </div>

  <div class="bg-black/30 p-8 rounded-2xl text-center">
    <a href="/tienda/checkout"
       class="bg-gradient-to-r from-blue-500 to-purple-500 px-12 py-4 text-xl font-bold rounded-full hover:scale-105 transition-all duration-300 shadow-2xl mb-8 inline-block">
      🧾 Ir al checkout
    </a>
  </div>
</section>

<%- include('includes/footer.ejs') %>
