<%- include('includes/head.ejs') %>
<%- include('includes/nav.ejs') %>

<section class="bg-white/10 backdrop-blur-md rounded-3xl p-12 mb-20 shadow-2xl">
  <h2 class="text-3xl font-bold text-center mb-8">Pedidos de la Tiendita</h2>

  <% if (pedidos.length > 0) { %>
    <ul class="space-y-4">
      <% for (let p of pedidos) { %>
        <li class="bg-gray-900/60 border border-gray-700 rounded-2xl p-4">
          <p><strong>Cliente:</strong> <%= p.nombre_cliente %></p>
          <p><strong>Producto:</strong> <%= p.nombre_producto || p.producto_id %></p>
          <p><strong>Cantidad:</strong> <%= p.cantidad %></p>
          <p class="text-xs opacity-70"><strong>Fecha:</strong> <%= p.fecha %></p>

          <button
            type="button"
            class="mt-3 px-4 py-1 bg-blue-600 rounded-full text-sm hover:bg-blue-500 transition"
            data-pedido-id="<%= p.id %>"
            onclick="cargarDetallePedido(<%= p.id %>)">
            Ver detalle AJAX
          </button>
        </li>
      <% } %>
    </ul>
  <% } else { %>
    <h3 class="text-center text-xl opacity-80">Aún no hay pedidos registrados.</h3>
  <% } %>

  <div id="detalle-pedido-ajax"
       class="mt-8 p-4 bg-black/40 rounded-2xl border border-gray-700 hidden">
    <h3 class="text-2xl font-bold mb-2">Detalle del pedido (AJAX)</h3>
    <div id="detalle-pedido-ajax-contenido" class="text-sm space-y-1"></div>
  </div>

  <p class="mt-8 text-xs opacity-60">
    Componente AJAX: detalle de pedido cargado dinámicamente con fetch (sin recargar la página).
  </p>
</section>

<%- include('includes/footer.ejs') %>
