<%- include('includes/head.ejs') %>
<%- include('includes/nav.ejs') %>

<section class="bg-white/10 backdrop-blur-md rounded-3xl p-12 mb-20 shadow-2xl">
  <h2 class="text-3xl font-bold mb-8 text-center">Administrar productos</h2>

  <% if (productos.length === 0) { %>
    <p class="text-center opacity-80">No hay productos registrados.</p>
  <% } else { %>
    <div class="space-y-8">
      <% for (let p of productos) { %>
        <form action="/tienda/admin/productos" method="POST" enctype="multipart/form-data"
              class="bg-gray-900/60 border border-gray-700 rounded-2xl p-6 grid md:grid-cols-2 gap-6">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <input type="hidden" name="id" value="<%= p.id %>">
          <input type="hidden" name="imagen_actual" value="<%= p.imagen || '' %>">

          <div class="space-y-3">
            <div>
              <label class="block mb-1 font-semibold">Nombre:</label>
              <input type="text" name="nombre" value="<%= p.nombre %>" required
                     class="w-full p-2 bg-gray-900 border border-gray-600 rounded-xl">
            </div>

            <div>
              <label class="block mb-1 font-semibold">Precio:</label>
              <input type="number" step="0.01" name="precio" value="<%= p.precio %>" required
                     class="w-full p-2 bg-gray-900 border border-gray-600 rounded-xl">
            </div>

            <div>
              <label class="block mb-1 font-semibold">Descripción:</label>
              <input type="text" name="descripcion" value="<%= p.descripcion %>"
                     class="w-full p-2 bg-gray-900 border border-gray-600 rounded-xl">
            </div>

            <div>
              <label class="block mb-1 font-semibold">Máx. unidades:</label>
              <input type="number" name="max_unidades" value="<%= p.max_unidades %>" required
                     class="w-full p-2 bg-gray-900 border border-gray-600 rounded-xl">
            </div>

            <div>
              <label class="block mb-1 font-semibold">Nueva imagen (opcional):</label>
              <input type="file" name="imagen" accept="image/png,image/jpg,image/jpeg"
                     class="w-full text-sm">
              <p class="text-xs opacity-70 mt-1">
                Si no seleccionas nada, se mantiene la imagen actual.
              </p>
            </div>

            <button type="submit"
                    class="bg-gradient-to-r from-blue-500 to-purple-500 px-6 py-2 rounded-full font-bold hover:scale-105 transition-all">
              Guardar cambios
            </button>
          </div>

          <div class="flex flex-col items-center justify-center">
            <% if (p.imagen) { %>
              <img src="<%= p.imagen %>" alt="<%= p.nombre %>" class="max-h-48 rounded-xl mb-2">
            <% } else { %>
              <p class="text-sm opacity-70 mb-2">Sin imagen.</p>
            <% } %>
          </div>
        </form>
      <% } %>
    </div>
  <% } %>
  <p class="mt-6 text-xs opacity-60">
    Triggers en BD: 
    1) Al crear un pedido se actualiza automáticamente el total de pedidos por producto. 
    2) Al cambiar la cantidad de un pedido se registra el cambio en una tabla de bitácora.
  </p>
</section>

<%- include('includes/footer.ejs') %>
