/*
Materiales(Clave, Descripción, Costo)
Proveedores(RFC, RazonSocial)
Proyectos(Numero,Denominacion)
Entregan(Clave, RFC, Numero, Fecha, Cantidad) 
*/

select * from materiales,entregan
where materiales.clave = entregan.clave
-- Unicamente salen los materiales entregados porque se exige que cada uno tenga una clave coincidente con la tabla entregan

(select * from entregan where clave = 1450)
union
(select * from entregan where clave = 1300);
-- una consulta equivalente sin union seria:
select *
from emtregan
where clave = 1450 or clave = 1300;

/*
(select * from entregan)
minus
(select * from entregan where clave=1000)
*/
-- una consulta equivalente sin minus seria:
select * 
from entregan
where clave <> 1000;

set dateormat dmy;
select m.descripcion
from entregan e
where m.clave = e.clave
and e.fecha >= '01/01/2000'
and e.fecha < '01/01/2001';
-- Algunas descripciones aparecen varias veces porque un mismo material puede haberse entregado varias veces
select distinct m.descripcion
from entregan e
where m.clave = e.clave
and e.fecha >= '01/01/2000'
and e.fecha < '01/01/2001';
-- Ahora cada material aparece solo una vez, ya que distinct elimina filas duplicadas del resultado

select p.numero, p.denominacion, e.fecha, e.cantidad
from proyectos p
where e.numero = p.numero
order by p.numero asc, e.fecha desc;

select * 
from productos
where descripcion like 'Si%';
-- Salen todas las filas donde la descripción empieza por “Si” y luego puede haber cero o más caracteres
-- El símbolo % es un comodín que representa “cero o más caracteres de cualquier tipo”
-- Si la consulta fuera LIKE 'Si' sin %, solo encontraría descripciones exactamente iguales a “Si”, sin ningún carácter adicional
-- Por eso LIKE 'Si' devolverá nada o muy pocas filas, mientras que LIKE 'Si%' devuelve todas las cadenas que empiezan con “Si”

