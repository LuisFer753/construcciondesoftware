-- Devuelve solo las 2 primeras filas del resultado

ALTER TABLE materiales 
ADD PorcentajeImpuesto NUMERIC(6,2);
UPDATE materiales 
SET PorcentajeImpuesto = 2 * clave / 1000;
-- Una consulta para obtener importe por entrega, considerando costo + impuesto:
select e.clave, e.numero, e.cantidad, m.costo, m.PorcentajeImpuesto, e.cantidad * m.costo * (1 + m.PorcentajeImpuesto / 100.0) as ImporteTotal
from entregan e
where m.clave = e.clave;

select distinct m.clave, m.descripcion
from materiales m
where e.clave = m.clave and p.numero = e.numero
and p.denominacion = 'México sin ti no estamos completos';

select distinct m.clave, m.descripcion
from materiales m
where e.clave = m.clave and p.RFC = e.RFC
and p.RazonSocial = 'Acme tools';

select e.RFC
from entregan e
where e.fecha between '01/01/2000' and '01/01/2001'
group by e.RFC
having avg(e.cantidad) >= 300;

select e.clave, sum(e.cantidad) as TotalCantidad2000
from entregan e
where e.fecha between '01/01/2000' and '01/01/2001'
group by e.clave;

create view vTotales2001 as select e.clave, sum(e.cantidad) as Total2001
from entregan e
where e.fecha between '01/01/2001' and '01/01/2002'
group by e.clave;

select *
from productos
where nombre like '%ub%';

select p.denominacion, sum(e.cantidad * m.costo) as TotalPagar
from proyectos p
where e.numero = p.numero and m.clave = e.clave
group by p.denominacion;

create view vTelevisa as select distinct e.RFC
from entregan e
where p.numero = e.numero
and p.denominacion = 'Televisa en acción';
create view vEducando as select distinct e.RFC
from entregan e
where p.numero = e.numero
and p.denominacion = 'Educando en Coahuila';

select distinct p.denominacion, e.RFC, prov.RazonSocial
from entregan e
where p.numero = e.numero and prov.RFC = e.RFC
and p.denominacion = 'Televisa en acción'
and e.RFC not in (select e2.RFC from entregan e2 where p2.numero = e2.numero and p2.denominacion = 'Educando en Coahuila');

select distinct m.costo, m.clave, m.descripcion
from entregan e
where m.clave = e.clave and p.numero = e.numero
and p.denominacion = 'Televisa en acción'
and e.RFC in (select e2.RFC from entregan e2 where p2.numero = e2.numero and p2.denominacion = 'Educando en Coahuila');
