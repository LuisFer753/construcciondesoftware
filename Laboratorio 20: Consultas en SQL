SELECT RFC FROM Entregan WHERE RFC LIKE '[A-D]%';
--  [A-D] indica un rango o conjunto de caracteres validos, seguidos de cero o mas caracteres cualesquiera, devolviendo un RFC que empiece con A, B, C o D
SELECT RFC FROM Entregan WHERE RFC LIKE '[^A]%';
-- [^A] Indica que haya cualquier caracter excepto el que se indica, seguido de cero o mas caracteres cualesquiera, devolviendo un RFC que no empiece con A
SELECT Numero FROM Entregan WHERE Numero LIKE '___6';
-- _ _ _ 6 Indica un caracter cualquiera por cada guion bajo, cumpliendo con cualquiera que se especifique, aqui devuelve cualquier numero de 4 digitos que termine en 6, ej: 1006

SELECT Clave,RFC,Numero,Fecha,Cantidad
FROM Entregan
WHERE Numero BETWEEN 5000 AND 5010
-- para definir un rango de fecha se agrega:
and fecha between '01/01/2000' and '31/12/2000';

SELECT RFC,Cantidad, Fecha,Numero
FROM Entregan
WHERE Numero Between 5000 and 5010 AND
Exists ( SELECT RFC FROM Proveedores WHERE RazonSocial LIKE 'La%' and Entregan.RFC = Proveedores.RFC )
-- Devuelve entregas con número entre 5000 y 5010 cuyo proveedor tiene razón social que empieza por “La”
-- ​El paréntesis después de EXISTS contiene la subconsulta; EXISTS solo comprueba si esa subconsulta devuelve al menos una fila (verdadero o falso)
-- Equivalente con in:
SELECT RFC, Cantidad, Fecha, Numero
FROM Entregan
WHERE Numero Between 5000 and 5010
AND RFC IN (SELECT RFC FROM Proveedores WHERE RazonSocial LIKE 'La%');
-- Equivalente con not in:
SELECT RFC, Cantidad, Fecha, Numero
FROM Entregan
WHERE Numero Between 5000 and 5010
AND RFC NOT IN (SELECT RFC FROM Proveedores WHERE RazonSocial LIKE 'La%');

